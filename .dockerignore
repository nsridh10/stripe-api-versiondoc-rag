# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Local dev configs / secrets ───────────────────────────────────────────────
.env
.env.*
*.env

# ── Evaluation outputs (not needed in container) ──────────────────────────────
data/eval/
src/eval/

# ── Test files (not needed in container) ──────────────────────────────────────
src/test\ files/

